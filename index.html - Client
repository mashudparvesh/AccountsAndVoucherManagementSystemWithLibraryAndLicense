        function toggleClientField() {
            const type = document.getElementById('type').value;
            const category = document.getElementById('category').value;
            const clientField = document.getElementById('clientField');
            const showForDue = (category === 'Due') && (type === 'Payment' || type === 'Purchase' || type === 'Expenses');
            const showForDuePayment = type === 'Due Payment';
            const showForSalesCredit = type === 'Sales' && category === 'Credit';
            const showForCreditPayment = type === 'Receive' && (category === 'Credit payment by Cash' || category === 'Credit payment by Bank');

            if (showForDue || showForDuePayment || showForSalesCredit || showForCreditPayment) {
                clientField.style.display = 'block';
                updateClientAutocomplete();
            } else {
                clientField.style.display = 'none';
                document.getElementById('client').value = '';
            }
        }

        function updateClientAutocomplete() {
            const type = document.getElementById('type').value;
            const category = document.getElementById('category').value;
            let allowedTypes = [];
            if (type === 'Receive') {
                if (category === 'Credit payment by Cash' || category === 'Credit payment by Bank') {
                    allowedTypes = ['Buyer'];
                } else {
                    allowedTypes = [];
                }
            } else if (type === 'Sales' && category === 'Credit') {
                allowedTypes = ['Buyer'];
            } else if (type === 'Due Payment') {
                allowedTypes = ['Seller'];
            } else if ((type === 'Payment' || type === 'Purchase' || type === 'Expenses') && category === 'Due') {
                allowedTypes = ['Seller'];
            } else {
                allowedTypes = [];
            }
            let filtered = allClients.filter(c => allowedTypes.includes(c.type)).map(c => c.name);
            $("#client").autocomplete({
                source: filtered,
                minLength: 1,
                select: function(event, ui) {
                    $(this).val(ui.item.value);
                    return false;
                }
            });
