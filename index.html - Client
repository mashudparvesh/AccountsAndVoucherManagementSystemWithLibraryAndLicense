        // =================== VOUCHER CREATION ===================
        function generateVoucherNumber() {
            const type = document.getElementById('type').value;
            const category = document.getElementById('category').value;
            const date = document.getElementById('date').value;
            if (!type || !category || !date) return;
            const d = new Date(date);
            const month = ["JAN","FEB","MAR","APR","MAY","JUN","JUL","AUG","SEP","OCT","NOV","DEC"][d.getMonth()];
            const year = d.getFullYear().toString().slice(-2);
            let typePrefix = { 'Payment':'PY', 'Purchase':'PU', 'Expenses':'EX', 'Receive':'RC', 'Due Payment':'DP', 'Sales':'SA' }[type] || 'V';
            let catMap = { 'Paid':'C', 'Due':'D', 'Cash':'C', 'Bank':'B', 'Credit':'R', 'Credit payment by Cash':'PC', 'Credit payment by Bank':'PB' };
            let catPrefix = catMap[category] || 'X';
            document.getElementById('voucherNumber').value = typePrefix + catPrefix + '-' + month + year + '-0001';
        }

        function createVoucher() {
            let type = document.getElementById('type').value;
            let category = document.getElementById('category').value;
            let date = document.getElementById('date').value;
            let items = getItemsFromForm();
            let client = document.getElementById('client').value.trim();

            if (!type || !category || !date || items.length === 0) {
                alert('Please fill all fields and at least one item.');
                return;
            }
            for (let item of items) {
                if (!item.particulars || item.amount <= 0) {
                    alert('Each item must have particulars and a positive amount.');
                    return;
                }
            }
            if ((category === 'Due' && (type === 'Payment' || type === 'Purchase' || type === 'Expenses')) ||
                type === 'Due Payment' ||
                (type === 'Sales' && category === 'Credit') ||
                (type === 'Receive' && (category === 'Credit payment by Cash' || category === 'Credit payment by Bank'))) {
                if (!client) {
                    alert('Please select a client for this transaction.');
                    return;
                }
            }

            const formData = { date, type, category, items: items, totalAmount: items.reduce((s,i)=>s+i.amount,0), party: client };

            document.getElementById('createBtn').innerHTML = '<i class="fas fa-spinner fa-spin"></i> Creating...';
            document.getElementById('createBtn').disabled = true;

            google.script.run
                .withSuccessHandler(function(response) {
                    let result = JSON.parse(response);
                    if (result.success) {
                        currentVoucher = result;
                        updateVoucherPreview(result);
                        document.getElementById('voucherPreviewCard').style.display = 'block';
                        document.getElementById('instructionsCard').style.display = 'none';
                        document.getElementById('statusBadge').className = 'status-badge status-created';
                        document.getElementById('statusBadge').textContent = 'Created';
                        document.getElementById('postingResult').innerHTML = '';
                        checkVoucherStorage();
                        alert('✅ ' + result.message);
                    } else {
                        alert('❌ ' + result.message);
                    }
                    document.getElementById('createBtn').innerHTML = '<i class="fas fa-save"></i> Create Voucher';
                    document.getElementById('createBtn').disabled = false;
                })
                .withFailureHandler(function(error) {
                    alert('Error: ' + error);
                    document.getElementById('createBtn').innerHTML = '<i class="fas fa-save"></i> Create Voucher';
                    document.getElementById('createBtn').disabled = false;
                })
                .createVoucher(JSON.stringify(formData));
        }

