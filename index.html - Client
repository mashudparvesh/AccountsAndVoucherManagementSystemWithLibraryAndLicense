                    document.getElementById('foundDate').textContent = r.voucher.date;
                    document.getElementById('foundAmount').textContent = r.voucher.totalAmount.toFixed(2);
                    document.getElementById('foundClient').textContent = r.voucher.party || '-';
                    let tbody = document.getElementById('foundItemsBody');
                    tbody.innerHTML = '';
                    r.voucher.items.forEach(item => {
                        tbody.innerHTML += `<tr><td>${item.sl}</td><td>${item.particulars}</td><td>৳${parseFloat(item.amount).toFixed(2)}</td></tr>`;
                    });
                    window.foundVoucher = r;
                } else {
                    document.getElementById('searchResults').style.display = 'none';
                    document.getElementById('noResults').style.display = 'block';
                    document.getElementById('noResults').innerHTML = '<i class="fas fa-exclamation-triangle"></i> ' + r.message;
                }
            }).searchVoucher(num);
        }

        function downloadFoundPDF() {
            if (window.foundVoucher) {
                let temp = currentVoucher;
                currentVoucher = window.foundVoucher;
                downloadPDF();
                currentVoucher = temp;
            }
        }
        function emailFoundVoucher() {
            if (window.foundVoucher) {
                let temp = currentVoucher;
                currentVoucher = window.foundVoucher;
                showEmailModal();
                currentVoucher = temp;
            }
        }
        function printFoundVoucher() {
            if (window.foundVoucher) printVoucher(window.foundVoucher);
        }

        // =================== EXPORT DATA ===================
        function exportData() {
            const startDate = document.getElementById('exportStartDate').value;
            const endDate = document.getElementById('exportEndDate').value;
            if (!startDate || !endDate) {
                alert('Please select both start and end dates.');
                return;
            }
            const format = document.querySelector('input[name="exportFormat"]:checked').value;
            if (!format) {
                alert('Please select a format.');
                return;
            }
            document.getElementById('exportModal').querySelector('.btn-primary').innerHTML = '<i class="fas fa-spinner fa-spin"></i> Exporting...';
            document.getElementById('exportModal').querySelector('.btn-primary').disabled = true;

            google.script.run
                .withSuccessHandler(function(response) {
                    let res = JSON.parse(response);
                    if (res.success) {
                        let link = document.createElement('a');
                        link.href = 'data:application/octet-stream;base64,' + res.base64;
                        link.download = res.filename;
                        link.click();
                        alert('✅ ' + res.message);
                    } else {
                        alert('❌ ' + res.message);
                    }
                    document.getElementById('exportModal').querySelector('.btn-primary').innerHTML = 'Export';
                    document.getElementById('exportModal').querySelector('.btn-primary').disabled = false;
                    bootstrap.Modal.getInstance(document.getElementById('exportModal')).hide();
                })
                .withFailureHandler(function(error) {
                    alert('Error: ' + error);
                    document.getElementById('exportModal').querySelector('.btn-primary').innerHTML = 'Export';
                    document.getElementById('exportModal').querySelector('.btn-primary').disabled = false;
                })
                .exportData(startDate, endDate, format);
        }

        document.getElementById('type').addEventListener('change', function() {
            updateCategoryOptions();
            generateVoucherNumber();
            updateClientAutocomplete();
        });
        document.getElementById('category').addEventListener('change', function() {
            generateVoucherNumber();
            toggleClientField();
        });
        document.getElementById('date').addEventListener('change', generateVoucherNumber);

        function openFinancialSummary() {
            loadFinancialSummary();
            new bootstrap.Modal(document.getElementById('financialSummaryModal')).show();
        }

        function refreshFinancialSummary() {
            loadFinancialSummary();
        }
    </script>
</body>
</html>
