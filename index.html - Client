    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // ==================== GLOBAL VARIABLES ====================
        let currentVoucher = null;
        let itemCounter = 1;
        let voucherToDelete = null;
        let allClients = [];
        let currentClientData = null;

        // ==================== INITIALIZATION ====================
        document.addEventListener('DOMContentLoaded', function() {
            document.getElementById('date').value = new Date().toISOString().split('T')[0];
            addItemRow();
            updateCategoryOptions();
            generateVoucherNumber();
            checkVoucherStorage();
            loadFinancialSummary();
            loadAllClients();
            loadCompanyInfo();
            $('#infoModal').on('show.bs.modal', function () {
                loadInfoData();
            });

            var today = new Date();
            var thirtyDaysAgo = new Date();
            thirtyDaysAgo.setDate(today.getDate() - 30);
            document.getElementById('exportStartDate').value = thirtyDaysAgo.toISOString().split('T')[0];
            document.getElementById('exportEndDate').value = today.toISOString().split('T')[0];
            
            var firstDayOfMonth = new Date(today.getFullYear(), today.getMonth(), 1);
            var lastDayOfMonth = new Date(today.getFullYear(), today.getMonth() + 1, 0);
            document.getElementById('reportStartDate').value = firstDayOfMonth.toISOString().split('T')[0];
            document.getElementById('reportEndDate').value = lastDayOfMonth.toISOString().split('T')[0];

            // ==================== LICENSE CHECK ====================
            checkLicenseStatus();
        });

        // ==================== LICENSE FUNCTIONS ====================
        var warningShown = false;

        function checkLicenseStatus() {
            google.script.run
                .withSuccessHandler(function(hasAny) {
                    if (!hasAny) {
                        document.getElementById('licenseMessage').innerHTML = '<i class="fas fa-exclamation-triangle me-2"></i> No license configured. Please contact admin.';
                        $('#licenseModal').modal('show');
                        disableApp(true);
                        return;
                    }

                    var activatedKey = localStorage.getItem('license_key');
                    var storedExpiry = localStorage.getItem('license_expiry');
                    if (activatedKey && storedExpiry) {
                        google.script.run
                            .withSuccessHandler(function(response) {
                                var data = JSON.parse(response);
                                if (data.success) {
                                    disableApp(false);
                                    checkExpiryWarning(data.expiration);
                                } else {
                                    localStorage.removeItem('license_key');
                                    localStorage.removeItem('license_expiry');
                                    document.getElementById('licenseMessage').innerHTML = '<i class="fas fa-times-circle me-2"></i> ' + data.message;
                                    $('#licenseModal').modal('show');
                                    disableApp(true);
                                }
                            })
                            .validateLicenseKey(activatedKey);
                    } else {
                        document.getElementById('licenseMessage').innerHTML = '<i class="fas fa-info-circle me-2"></i> Please enter your license key to continue.';
                        $('#licenseModal').modal('show');
                        disableApp(true);
                    }
                })
                .hasAnyLicense();
        }

        function verifyLicense() {
            var key = document.getElementById('licenseKeyInput').value.trim();
            if (!key) {
                alert('Please enter a license key.');
                return;
            }
            google.script.run
                .withSuccessHandler(function(response) {
                    var data = JSON.parse(response);
                    if (data.success) {
                        localStorage.setItem('license_key', key);
                        localStorage.setItem('license_expiry', data.expiration);
                        $('#licenseModal').modal('hide');
                        disableApp(false);
                        checkExpiryWarning(data.expiration);
                    } else {
                        document.getElementById('licenseMessage').innerHTML = '<i class="fas fa-times-circle me-2"></i> ' + data.message;
                    }
                })
                .validateLicenseKey(key);
        }

        function disableApp(disabled) {
            var mainContent = document.querySelector('.container');
            var licenseModal = document.getElementById('licenseModal');
            var allInteractive = document.querySelectorAll('button, input, select, textarea, .btn');
            allInteractive.forEach(el => {
                if (licenseModal && licenseModal.contains(el)) {
                    return;
                }
                el.disabled = disabled;
            });
            if (mainContent) {
                mainContent.style.opacity = disabled ? '0.5' : '1';
            }
        }

        function checkExpiryWarning(expiryDateStr) {
            if (warningShown) return;
            var expiry = new Date(expiryDateStr);
            var today = new Date();
            today.setHours(0, 0, 0, 0);
            var daysLeft = Math.ceil((expiry - today) / (1000 * 60 * 60 * 24));
            if (daysLeft <= 7 && daysLeft > 0) {
                showWarningMessage(daysLeft);
                warningShown = true;
            }
        }

        function showWarningMessage(daysLeft) {
            var warningHtml = `
                <div class="alert alert-warning alert-dismissible fade show" role="alert" style="position: fixed; top: 20px; right: 20px; z-index: 9999; max-width: 350px;">
                    <strong>⚠️ License Expiring Soon!</strong><br>
                    Your license will expire in ${daysLeft} day(s).<br>
                    Please contact <strong>+880 1775 316434</strong> or email <strong>mashudrus@gmail.com</strong> to renew.
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            `;
            document.body.insertAdjacentHTML('beforeend', warningHtml);
            setTimeout(function() {
                var alertDiv = document.querySelector('.alert-warning');
                if (alertDiv) alertDiv.remove();
            }, 10000);
        }

        // ==================== FINANCIAL REPORT FUNCTIONS ====================
        function generateFinancialReportPDF() {
            const startDate = document.getElementById('reportStartDate').value;
            const endDate = document.getElementById('reportEndDate').value;
            if (!startDate || !endDate) {
                alert('Please select both start and end dates.');
                return;
            }

            const btn = document.querySelector('#financialReportModal .btn-primary');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Generating...';
            btn.disabled = true;

            google.script.run
                .withSuccessHandler(function(response) {
                    const res = JSON.parse(response);
                    if (res.success) {
                        const link = document.createElement('a');
                        link.href = 'data:application/pdf;base64,' + res.base64;
                        link.download = res.filename;
                        link.click();
                    } else {
                        alert('❌ ' + res.message);
                    }
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                })
                .withFailureHandler(function(error) {
                    alert('Error: ' + error);
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                })
                .generateFinancialReportPDF(startDate, endDate);
        }

        function sendFinancialReportEmail() {
            const startDate = document.getElementById('reportStartDate').value;
            const endDate = document.getElementById('reportEndDate').value;
            if (!startDate || !endDate) {
                alert('Please select both start and end dates.');
                return;
            }

            const email = prompt('Enter recipient email address:');
            if (!email) return;

            const btn = document.querySelector('#financialReportModal .btn-warning');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Sending...';
            btn.disabled = true;

            google.script.run
                .withSuccessHandler(function(result) {
                    alert(result);
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                })
                .withFailureHandler(function(error) {
                    alert('Error: ' + error);
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                })
                .emailFinancialReport(email, startDate, endDate);
        }

        // ==================== INFO MANAGEMENT ====================
        function loadInfoData() {
            google.script.run
                .withSuccessHandler(function(response) {
                    let data = JSON.parse(response);
                    if (data.success) {
                        document.getElementById('infoCompanyName').value = data.info.name || '';
                        document.getElementById('infoAddress').value = data.info.address || '';
                        document.getElementById('infoPhone').value = data.info.phone || '';
                        document.getElementById('infoEmail').value = data.info.email || '';
                        document.getElementById('infoPreparedBy').value = data.info.preparedBy || '';
                        document.getElementById('infoAuthorizedBy').value = data.info.authorizedBy || '';
                        document.getElementById('infoAccountManager').value = data.info.accountManager || '';
                    } else {
                        alert('Failed to load company info: ' + data.message);
                    }
                })
                .withFailureHandler(function(error) {
                    alert('Error loading info: ' + error);
                })
                .getInfoData();
        }

        function saveInfo() {
            let infoData = {
                name: document.getElementById('infoCompanyName').value,
                address: document.getElementById('infoAddress').value,
                phone: document.getElementById('infoPhone').value,
                email: document.getElementById('infoEmail').value,
                preparedBy: document.getElementById('infoPreparedBy').value,
                authorizedBy: document.getElementById('infoAuthorizedBy').value,
                accountManager: document.getElementById('infoAccountManager').value
            };
            google.script.run
                .withSuccessHandler(function(response) {
                    let res = JSON.parse(response);
                    if (res.success) {
                        alert(res.message);
                        bootstrap.Modal.getInstance(document.getElementById('infoModal')).hide();
                        loadCompanyInfo();
                    } else {
                        alert('❌ ' + res.message);
                    }
                })
                .withFailureHandler(function(error) {
                    alert('Error: ' + error);
                })
                .updateInfoData(JSON.stringify(infoData));
        }

        function loadCompanyInfo() {
            google.script.run
                .withSuccessHandler(function(response) {
                    let data = JSON.parse(response);
                    if (data.success) {
                        document.getElementById('companyName').innerText = data.company.name || 'Voucher Management';
                        document.getElementById('companyAddress').innerText = data.company.address || 'Create, manage, and print vouchers with multiple items & clients';
                    }
                })
                .getCompanyInfo();
        }

        // ==================== CLIENT MANAGEMENT ====================
        function loadAllClients() {
            google.script.run
                .withSuccessHandler(function(response) {
                    let data = JSON.parse(response);
                    if (data.success) {
                        allClients = data.parties;
                        updateClientAutocomplete();
                        renderClientList();
                    }
                })
                .getParties();
