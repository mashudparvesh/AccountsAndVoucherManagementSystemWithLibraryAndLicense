<!DOCTYPE html>
<html>
<head>
    <base target="_top">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Voucher System</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css">
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>
    <style>
        /* ===== BLACK & YELLOW DARK THEME ===== */
        :root {
            --bg-dark: #0a0c0f;
            --card-dark: #1a1e24;
            --border-dark: #2c313a;
            --text-primary: #eef2f6;
            --text-secondary: #b0b9c9;
            --accent-yellow: #f5b342;
            --accent-yellow-hover: #ffc55c;
            --accent-green: #2ecc71;
            --accent-red: #e74c3c;
            --accent-blue: #3498db;
            --accent-warning: #f39c12;
            --shadow-dark: 0 8px 20px rgba(0,0,0,0.6);
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-primary);
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            padding: 24px;
            line-height: 1.6;
        }

        .container {
            max-width: 1400px;
        }

        .header-section {
            background: var(--card-dark);
            color: var(--text-primary);
            padding: 28px 32px;
            border-radius: 16px;
            margin-bottom: 28px;
            border: 1px solid var(--border-dark);
            box-shadow: var(--shadow-dark);
        }
        .header-section h1 {
            font-family: 'Poppins', sans-serif;
            font-weight: 600;
            font-size: 2rem;
            margin-bottom: 6px;
        }
        .header-section .company-name {
            color: var(--accent-yellow);
        }
        .header-section .company-address {
            font-family: 'Inter', sans-serif;
            color: var(--text-secondary);
            margin-bottom: 0;
        }

        .footer-section {
            text-align: center;
            padding: 20px;
            margin-top: 40px;
            color: var(--text-secondary);
            border-top: 1px solid var(--border-dark);
            font-size: 0.9rem;
        }
        .footer-section .developer {
            color: var(--accent-yellow);
            font-weight: 500;
        }

        .card {
            background: var(--card-dark);
            border: 1px solid var(--border-dark);
            border-radius: 16px;
            box-shadow: var(--shadow-dark);
            margin-bottom: 24px;
            transition: transform 0.1s ease, box-shadow 0.1s ease;
        }
        .card:hover {
            box-shadow: 0 12px 28px rgba(0,0,0,0.8);
        }
        .card-header {
            background: #0f131a;
            border-bottom: 1px solid var(--border-dark);
            color: var(--text-primary);
            font-weight: 600;
            padding: 16px 20px;
            border-radius: 16px 16px 0 0 !important;
        }
        .card-header.bg-primary {
            background: #1e252f !important;
            border-bottom: 2px solid var(--accent-yellow);
        }
        .card-header.bg-success {
            background: #1e252f !important;
            border-bottom: 2px solid var(--accent-yellow);
        }
        .card-header h4 {
            color: var(--accent-yellow);
        }

        .stat-card {
            background: #0f131a;
            border: 1px solid var(--border-dark);
            border-radius: 12px;
            padding: 18px 16px;
            text-align: center;
            transition: all 0.2s;
            height: 100%;
        }
        .stat-card:hover {
            border-color: var(--accent-yellow);
        }
        .stat-label {
            color: var(--text-secondary);
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }
        .stat-value {
            color: var(--accent-yellow);
            font-size: 1.8rem;
            font-weight: 700;
            line-height: 1.2;
        }
        .refresh-summary {
            color: var(--text-secondary);
            cursor: pointer;
            transition: color 0.2s;
        }
        .refresh-summary:hover {
            color: var(--accent-yellow);
        }

        .btn {
            border-radius: 8px;
            padding: 8px 8px;
            font-weight: 500;
            font-size: 0.95rem;
            transition: all 0.15s;
            border: none;
        }
        .btn-primary {
            background: var(--accent-yellow);
            color: #0a0c0f;
            font-weight: 600;
        }
        .btn-primary:hover {
            background: var(--accent-yellow-hover);
            color: #000;
        }
        .btn-success {
            background: var(--accent-green);
            color: #0a0c0f;
            font-weight: 600;
        }
        .btn-success:hover {
            background: #27ae60;
        }
        .btn-warning {
            background: var(--accent-warning);
            color: #0a0c0f;
            font-weight: 600;
        }
        .btn-warning:hover {
            background: #e67e22;
        }
        .btn-danger {
            background: var(--accent-red);
            color: white;
        }
        .btn-info {
            background: var(--accent-blue);
            color: white;
        }
        .btn-outline-secondary {
            background: transparent;
            border: 1px solid var(--border-dark);
            color: var(--text-secondary);
        }
        .btn-outline-secondary:hover {
            background: #2a313c;
            color: var(--text-primary);
            border-color: var(--accent-yellow);
        }

        .form-control, .form-select, .input-group-text {
            background: #0f131a;
            border: 1px solid var(--border-dark);
            color: var(--text-primary);
            border-radius: 8px;
            padding: 10px 14px;
            font-family: 'Inter', sans-serif;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--accent-yellow);
            box-shadow: 0 0 0 3px rgba(245, 179, 66, 0.2);
            background: #1a1f2a;
            color: white;
        }

        .ui-autocomplete {
            background-color: var(--card-dark);
            border: 1px solid var(--border-dark);
            color: var(--text-primary);
            max-height: 200px;
            overflow-y: auto;
        }
        .ui-menu-item {
            padding: 8px 12px;
            cursor: pointer;
        }
        .ui-state-active {
            background: var(--accent-yellow) !important;
            color: #0a0c0f !important;
        }

        .table {
            color: var(--text-primary);
        }
        .table thead th {
            background: #0f131a;
            color: var(--accent-yellow);
            font-weight: 600;
            border-bottom: 2px solid var(--accent-yellow);
        }
        .table td {
            border-color: var(--border-dark);
        }

        .voucher-preview {
            background: #0f131a;
            border-left: 4px solid var(--accent-yellow);
            padding: 20px;
            border-radius: 12px;
            margin-top: 16px;
            border: 1px solid var(--border-dark);
        }

        .status-badge {
            padding: 5px 14px;
            border-radius: 30px;
            font-size: 0.85rem;
            font-weight: 600;
            display: inline-block;
        }
        .status-created {
            background: #3a2e1f;
            color: var(--accent-yellow);
        }
        .status-posted {
            background: #1a3a2a;
            color: #2ecc71;
        }

        .modal-content {
            background: var(--card-dark);
            border: 1px solid var(--border-dark);
            border-radius: 16px;
        }
        .modal-header, .modal-footer {
            border-color: var(--border-dark);
        }
        .modal-title {
            color: var(--accent-yellow);
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header-section">
            <h1>
                <i class="fas fa-file-invoice-dollar me-2" style="color: var(--accent-yellow);"></i>
                <span id="companyName">Voucher Management</span>
            </h1>
            <p class="company-address" id="companyAddress">Create, manage, and print vouchers with multiple items & clients</p>
        </div>

        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-body d-flex flex-wrap gap-2 align-items-center">
                        <button class="btn btn-warning" onclick="setupSheets()" id="setupBtn" >
                            <i class="fas fa-cog me-1"></i> Setup Sheets
                        </button>
                        <span id="setupStatus" class="ms-2 text-warning"></span>
                        <div class="ms-auto d-flex gap-2">
                            <button class="btn btn-outline-secondary" onclick="openGoogleSheet()">
                                <i class="fas fa-external-link-alt me-1"></i> View Sheet
                            </button>
                            <button class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#searchModal">
                                <i class="fas fa-search me-1"></i> Search
                            </button>
                            <button class="btn btn-outline-secondary" onclick="checkVoucherStorage()" style="display:none;">
                                <i class="fas fa-sync-alt me-1"></i> Check Storage
                            </button>
                            <button class="btn btn-outline-secondary" onclick="createBackup()" id="backupBtn">
                                <i class="fas fa-copy me-1"></i> Backup
                            </button>
                            <button class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#exportModal">
                                <i class="fas fa-download me-1"></i> Export Data
                            </button>
                            <button class="btn btn-outline-secondary" onclick="openFinancialSummary()">
                                <i class="fas fa-chart-pie me-1"></i> Financial Summary
                            </button>
                            <button class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#financialReportModal">
                                <i class="fas fa-chart-line me-1"></i> Financial Report
                            </button>
                            <button class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#infoModal">
                                <i class="fas fa-building me-1"></i> Manage Info
                            </button>                            
                            <button class="btn btn-info" data-bs-toggle="modal" data-bs-target="#clientModal">
                                <i class="fas fa-users me-1"></i> Manage Clients
                            </button>
                            <button class="btn btn-primary" onclick="openClientSummary()">
                                <i class="fas fa-chart-bar me-1"></i> Client Summary
                            </button>                            
                        </div>
                    </div>
                </div>
            </div>
        </div>



        <div id="storageStatus" class="alert" style="display: none;"></div>

        <div class="row g-4">
            <div class="col-lg-6">
                <div class="card">
                    <div class="card-header bg-primary">
                        <h4 class="mb-0"><i class="fas fa-plus-circle me-2"></i>Create New Voucher</h4>
                    </div>
                    <div class="card-body">
                        <form id="voucherForm">
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Date *</label>
                                <input type="date" id="date" class="form-control" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Voucher Number</label>
                                <div class="input-group">
                                    <input type="text" id="voucherNumber" class="form-control" placeholder="Auto-generated" readonly>
                                    <button type="button" class="btn btn-outline-secondary" onclick="generateVoucherNumber()">
                                        <i class="fas fa-bolt"></i> Preview
                                    </button>
                                </div>
                                <small class="text-muted">
                                    Format: PYC-JAN26-0001 (Payment-Cash), SAC-JAN26-0001 (Sales-Cash), SAR-JAN26-0001 (Sales-Credit)
                                </small>
                            </div>
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Type *</label>
                                    <select id="type" class="form-select" required onchange="updateCategoryOptions(); updateClientAutocomplete();">
                                        <option value="">Select Type</option>
                                        <option value="Payment">Payment</option>
                                        <option value="Purchase">Purchase</option>
                                        <option value="Expenses">Expenses</option>
                                        <option value="Receive">Receive</option>
                                        <option value="Due Payment">Due Payment</option>
                                        <option value="Sales">Sales</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Category *</label>
                                    <select id="category" class="form-select" required onchange="toggleClientField();">
                                    </select>
                                </div>
                            </div>
                            <div class="mb-3" id="clientField" style="display: none;">
                                <label class="form-label fw-semibold">Client</label>
                                <input type="text" id="client" class="form-control" placeholder="Type to search or select client">
                                <small class="text-muted">Select a client for due/credit transactions</small>
                            </div>
                            <label class="form-label fw-semibold">Items *</label>
                            <div class="table-responsive mb-2">
                                <table class="table table-bordered align-middle" id="itemsTable">
                                    <thead>
                                        <tr>
                                            <th style="width:10%">SL</th>
                                            <th style="width:60%">Particulars</th>
                                            <th style="width:20%">Amount (BDT)</th>
                                            <th style="width:10%"></th>
                                        </thead>
                                    <tbody id="itemsBody"></tbody>
                                </table>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <button type="button" class="btn btn-sm btn-success" onclick="addItemRow()">
                                    <i class="fas fa-plus me-1"></i> Add Item
                                </button>
                                <h5 class="mb-0" style="color: var(--accent-yellow);">Total: ৳ <span id="totalAmount">0.00</span></h5>
                            </div>
                            <div class="d-flex flex-wrap gap-2">
                                <button type="button" class="btn btn-success" onclick="createVoucher()" id="createBtn">
                                    <i class="fas fa-save me-2"></i>Create Voucher
                                </button>
                                <button type="button" class="btn btn-secondary" onclick="clearForm()">
                                    <i class="fas fa-redo me-2"></i>Clear Form
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="card" id="voucherPreviewCard" style="display: none;">
                    <div class="card-header bg-success">
                        <h4 class="mb-0"><i class="fas fa-eye me-2"></i>Voucher Actions</h4>
                    </div>
                    <div class="card-body">
                        <div class="voucher-preview">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h5 class="fw-semibold mb-0" style="color: var(--accent-yellow);">
                                    <i class="fas fa-file-alt me-2"></i><span id="previewVoucherNo"></span>
                                </h5>
                                <span class="status-badge status-created" id="statusBadge">Created</span>
                            </div>
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <p class="mb-2"><strong>Type:</strong> <span id="previewType"></span></p>
                                    <p class="mb-2"><strong>Date:</strong> <span id="previewDate"></span></p>
                                </div>
                                <div class="col-md-6">
                                    <p class="mb-2"><strong>Category:</strong> <span id="previewCategory"></span></p>
                                    <p class="mb-2"><strong>Total:</strong> ৳<span id="previewAmount"></span></p>
                                </div>
                            </div>
                            <div class="mb-2">
                                <p class="mb-1"><strong>Client:</strong> <span id="previewClient">-</span></p>
                            </div>
                            <div class="mb-3">
                                <p class="mb-1"><strong>Items:</strong></p>
                                <div class="table-responsive">
                                    <table class="table table-sm table-bordered">
                                        <thead><tr><th>SL</th><th>Particulars</th><th>Amount</th></tr></thead>
                                        <tbody id="previewItems"></tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                        <div id="postingProgress" class="posting-progress mt-4" style="display: none;">
                            <h6 class="fw-semibold">Posting Progress:</h6>
                            <div class="progress-step"><div class="step-icon step-pending" id="step1">1</div><div class="step-text">Transactions Sheet</div></div>
                            <div class="progress-step"><div class="step-icon step-pending" id="step2">2</div><div class="step-text" id="step2Text">Type Sheet</div></div>
                            <div class="progress-step"><div class="step-icon step-pending" id="step3">3</div><div class="step-text" id="step3Text">Category Sheet</div></div>
                            <div class="progress-step"><div class="step-icon step-pending" id="step4">4</div><div class="step-text">Summary Sheet</div></div>
                        </div>
                        <div id="postingResult" class="mt-3"></div>
                        <div class="d-flex flex-wrap gap-2 mt-3">
                            <button class="btn btn-primary" onclick="downloadPDF()" id="downloadBtn"><i class="fas fa-download me-2"></i>PDF</button>
                            <button class="btn btn-warning" onclick="showEmailModal()" id="emailBtn"><i class="fas fa-envelope me-2"></i>Email</button>
                            <button class="btn btn-info" onclick="printVoucherFromPreview()" id="printBtn"><i class="fas fa-print me-2"></i>Print</button>
                            <button class="btn btn-success" onclick="postVoucher()" id="postBtn"><i class="fas fa-paper-plane me-2"></i>Post</button>
                        </div>
                    </div>
                </div>
                <div class="card" id="instructionsCard">
                    <div class="card-header bg-light" style="background: #0f131a !important;">
                        <h4 class="mb-0" style="color: var(--accent-yellow);"><i class="fas fa-info-circle me-2"></i>Instructions</h4>
                    </div>
                    <div class="card-body text-center py-5">
                        <i class="fas fa-file-alt fa-4x text-secondary mb-3"></i>
                        <h5 class="text-secondary">No Voucher Created</h5>
                        <p class="text-muted">Fill the form and click "Create Voucher"</p>
                        <ol class="text-start text-muted mt-4" style="max-width: 300px; margin: 0 auto;">
                            <li>Click "Setup Sheets" first time</li>
                            <li>Add multiple items using "Add Item"</li>
                            <li>For due/credit transactions, select a client</li>
                            <li>Create voucher, then download PDF, email, or print</li>
                            <li>Click "Post" to save to Google Sheets</li>
                        </ol>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Email Modal -->
    <div class="modal fade" id="emailModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fas fa-paper-plane me-2"></i>Send Voucher via Email</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label>Recipient Email Address</label>
                        <input type="email" id="recipientEmail" class="form-control" placeholder="example@gmail.com" required>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" onclick="sendEmail()">Send Email</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Search Modal -->
    <div class="modal fade" id="searchModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fas fa-search me-2"></i>Search Voucher</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label>Enter Voucher Number</label>
                        <div class="input-group">
                            <input type="text" id="searchVoucherNumber" class="form-control" placeholder="e.g., PUC-JAN26-0001" required>
                            <button class="btn btn-primary" onclick="searchVoucher()"><i class="fas fa-search me-2"></i>Search</button>
                        </div>
                    </div>
                    <div id="searchResults" style="display: none;">
                        <div class="card mt-3">
                            <div class="card-header bg-success">
                                <h6 class="mb-0"><i class="fas fa-check-circle me-2"></i>Voucher Found</h6>
                            </div>
                            <div class="card-body">
                                <div class="voucher-preview">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <h5 class="fw-semibold mb-0" style="color: var(--accent-yellow);"><i class="fas fa-file-alt me-2"></i><span id="foundVoucherNo"></span></h5>
                                        <span class="status-badge status-posted">Posted</span>
                                    </div>
                                    <div class="row mb-3">
                                        <div class="col-md-6">
                                            <p class="mb-2"><strong>Type:</strong> <span id="foundType"></span></p>
                                            <p class="mb-2"><strong>Date:</strong> <span id="foundDate"></span></p>
                                        </div>
                                        <div class="col-md-6">
                                            <p class="mb-2"><strong>Category:</strong> <span id="foundCategory"></span></p>
                                            <p class="mb-2"><strong>Total:</strong> ৳<span id="foundAmount"></span></p>
                                        </div>
                                    </div>
                                    <div class="mb-2">
                                        <p class="mb-1"><strong>Client:</strong> <span id="foundClient">-</span></p>
                                    </div>
                                    <div class="mb-3">
                                        <p><strong>Items:</strong></p>
                                        <div class="table-responsive">
                                            <table class="table table-sm table-bordered">
                                                <thead><tr><th>SL</th><th>Particulars</th><th>Amount</th></tr></thead>
                                                <tbody id="foundItemsBody"></tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                                <div class="d-flex flex-wrap gap-2 mt-3">
                                    <button class="btn btn-primary" onclick="downloadFoundPDF()"><i class="fas fa-download me-2"></i>PDF</button>
                                    <button class="btn btn-warning" onclick="emailFoundVoucher()"><i class="fas fa-envelope me-2"></i>Email</button>
                                    <button class="btn btn-info" onclick="printFoundVoucher()"><i class="fas fa-print me-2"></i>Print</button>
                                    <button class="btn btn-danger" onclick="showDeleteConfirmation()"><i class="fas fa-trash me-2"></i>Delete</button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div id="noResults" class="alert alert-warning mt-3" style="display: none;"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div class="modal fade" id="deleteConfirmModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fas fa-exclamation-triangle me-2" style="color: var(--accent-red);"></i>Confirm Deletion</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="text-warning mb-3">This action is permanent and cannot be undone.</p>
                    <p>Type <strong style="color: var(--accent-yellow);">DELETE</strong> to confirm:</p>
                    <input type="text" id="deleteConfirmInput" class="form-control" placeholder="DELETE">
                </div>
                <div class="modal-footer">
