        function getItemsFromForm() {
            let items = [];
            let rows = document.querySelectorAll('#itemsBody tr');
            rows.forEach(row => {
                let sl = row.cells[0].querySelector('input').value;
                let particulars = row.cells[1].querySelector('input').value;
                let amount = row.cells[2].querySelector('input').value;
                if (particulars && amount) {
                    items.push({ sl: parseInt(sl), particulars, amount: parseFloat(amount) });
                }
