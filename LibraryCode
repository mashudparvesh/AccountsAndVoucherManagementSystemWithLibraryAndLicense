// =================== BACKUP FUNCTIONS ===================
function createBackup() {
  try {
    var originalName = ss.getName();
    var timestamp = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "yyyy-MM-dd HH:mm");
    var backupName = originalName + " Backup " + timestamp;
    var backupSS = SpreadsheetApp.create(backupName);
    
    ss.getSheets().forEach(function(sheet) {
      var newSheet = sheet.copyTo(backupSS);
      newSheet.setName(sheet.getName());
    });
    
    var defaultSheet = backupSS.getSheets()[0];
    if (defaultSheet.getName() === "Sheet1" && defaultSheet.getLastRow() === 0) {
      backupSS.deleteSheet(defaultSheet);
    }
    
    var backupUrl = backupSS.getUrl();
    var fileId = backupSS.getId();
    
    return JSON.stringify({
      success: true,
      message: '✅ Backup created successfully!',
      backupName: backupName,
      backupUrl: backupUrl,
      fileId: fileId,
      timestamp: timestamp
    });
  } catch (error) {
    return JSON.stringify({ success: false, message: '❌ Backup failed: ' + error.toString() });
  }
}

function emailBackup(fileId, email) {
  try {
    var backupSS = SpreadsheetApp.openById(fileId);
    var sheets = backupSS.getSheets();
    var zipBlobs = [];
    
    sheets.forEach(function(sheet) {
      var sheetName = sheet.getName();
      var data = sheet.getDataRange().getValues();
      var csv = convertToCSV(data);
      var blob = Utilities.newBlob(csv, 'text/csv', sheetName + '.csv');
      zipBlobs.push(blob);
    });
    
    var zipBlob = Utilities.zip(zipBlobs, backupSS.getName() + '.zip');
    
    MailApp.sendEmail({
      to: email,
      subject: 'Backup: ' + backupSS.getName(),
      body: 'Please find attached the complete backup as CSV files inside a ZIP archive.\n\nGenerated on: ' + new Date().toLocaleString(),
      attachments: [zipBlob]
    });
    return JSON.stringify({ success: true, message: '✅ Backup sent to ' + email });
  } catch (error) {
    return JSON.stringify({ success: false, message: '❌ Email error: ' + error.toString() });
  }
}

function convertToCSV(data) {
  var csv = '';
  data.forEach(function(row) {
    var rowStr = row.map(function(cell) {
      if (typeof cell === 'string' && (cell.indexOf(',') !== -1 || cell.indexOf('"') !== -1)) {
        return '"' + cell.replace(/"/g, '""') + '"';
      }
      return cell;
    }).join(',');
    csv += rowStr + '\r\n';
  });
  return csv;
}

// =================== EXPORT DATA ===================
function exportData(startDateStr, endDateStr, format) {
  try {
    var sheetsToExport = getExportSheets();
    var zipBlobs = [];
    var allHtml = '';
    var company = getCompanyInfoParsed();

    for (var s = 0; s < sheetsToExport.length; s++) {
      var sheet = sheetsToExport[s];
      var sheetName = sheet.getName();
      var data;
      
      if (sheetName === 'Transactions') {
        var allData = sheet.getDataRange().getValues();
        var headers = allData[0];
        var filteredRows = [];
        var startDate = new Date(startDateStr);
        var endDate = new Date(endDateStr);
        startDate.setHours(0,0,0,0);
        endDate.setHours(23,59,59,999);
        
        for (var i = 1; i < allData.length; i++) {
          var row = allData[i];
          var dateVal = row[1];
          if (!dateVal) continue;
          var rowDate = parseDateForExport(dateVal);
          if (rowDate >= startDate && rowDate <= endDate) {
            row[1] = storeDateSimply(dateVal);
            filteredRows.push(row);
          }
        }
        data = [headers].concat(filteredRows);
      } else {
        data = sheet.getDataRange().getValues();
      }
      
      if (data.length <= 1) continue;
      
      var csv = convertToCSV(data);
      var csvBlob = Utilities.newBlob(csv, 'text/csv', sheetName + '.csv');
      
      if (format === 'PDF') {
        var isLastSheet = (s === sheetsToExport.length - 1);
        var html = generateSheetHTML(data, sheetName, company, isLastSheet);
        allHtml += html;
      } else {
        zipBlobs.push(csvBlob);
      }
    }
    
    if (format === 'PDF') {
      if (!allHtml) return JSON.stringify({ success: false, message: 'No data to export.' });
      
      allHtml = allHtml.replace(/<div style="page-break-before: always;"><\/div>\s*$/, '');
      
      var finalHtml = '<html><head><meta charset="UTF-8"><style>' +
        '@page { @bottom-right { content: "Page " counter(page) " of " counter(pages); font-size: 8px; color: #666; } } ' +
        'body { margin: 0; padding: 20px; font-family: Arial, sans-serif; } ' +
        '@media print { div[style*="page-break"] { page-break-before: avoid; } }' +
        '</style></head><body>' + allHtml + '</body></html>';
      
      var htmlBlob = Utilities.newBlob(finalHtml, MimeType.HTML, 'export.html');
      var pdfBlob = htmlBlob.getAs(MimeType.PDF);
      var base64 = Utilities.base64Encode(pdfBlob.getBytes());
      return JSON.stringify({ success: true, base64: base64, filename: 'export_' + startDateStr + '_to_' + endDateStr + '.pdf', message: 'Export successful' });
    } else {
      if (zipBlobs.length === 0) {
        return JSON.stringify({ success: false, message: 'No data to export.' });
      }
      var zipBlob = Utilities.zip(zipBlobs, 'export_' + startDateStr + '_to_' + endDateStr + '.zip');
      var base64 = Utilities.base64Encode(zipBlob.getBytes());
      return JSON.stringify({ success: true, base64: base64, filename: 'export_' + startDateStr + '_to_' + endDateStr + '.zip', message: 'Export successful' });
    }
  } catch (error) {
    return JSON.stringify({ success: false, message: error.toString() });
  }
}

function getExportSheets() {
  var allSheets = ss.getSheets();
  var exclude = ['Info', 'Parties'];
  var exportSheets = [];
  for (var i = 0; i < allSheets.length; i++) {
    if (exclude.indexOf(allSheets[i].getName()) === -1) {
      exportSheets.push(allSheets[i]);
    }
  }
  return exportSheets;
}

function parseDateForExport(dateVal) {
  if (dateVal instanceof Date) {
    return new Date(dateVal.getFullYear(), dateVal.getMonth(), dateVal.getDate());
  }
  if (typeof dateVal === 'string') {
    var parts = dateVal.split('-');
    if (parts.length === 3) {
      return new Date(parts[2], parts[1] - 1, parts[0]);
    }
  }
  return new Date(dateVal);
}

function generateSheetHTML(data, sheetName, company, isLastSheet = false) {
  if (!data || data.length === 0) return '';
  var rows = '';
  for (var i = 1; i < data.length; i++) {
    var row = data[i];
    rows += '<tr>';
    for (var j = 0; j < row.length; j++) {
      var cell = row[j];
      if (j === 6 && typeof cell === 'number') {
        rows += '<td style="text-align: right; white-space: nowrap;">৳ ' + cell.toFixed(2) + '</td>';
      } else {
        rows += '<td>' + escapeHtml(String(cell)) + '</td>';
      }
    }
    rows += '</tr>';
  }
  
  var headers = data[0];
  var headerRow = '<tr>';
  for (var k = 0; k < headers.length; k++) {
    headerRow += '<th>' + escapeHtml(String(headers[k])) + '</th>';
  }
  headerRow += '</tr>';
  
  var printDate = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "dd-MM-yyyy hh:mm a");
  
  var sheetHtml = '<div style="margin-bottom: 30px; font-family: Arial, sans-serif;">\n' +
    '  <div style="text-align: center; margin-bottom: 20px; border-bottom: 1px solid #ddd; padding-bottom: 10px;">\n' +
    '    <div style="font-size: 24px; font-weight: bold; color: #2c3e50;">' + escapeHtml(company.name || 'Your Company') + '</div>\n' +
    '    <div style="font-size: 12px; color: #666;">' + escapeHtml(company.address || '') + '</div>\n' +
    '    <div style="font-size: 12px; color: #666;">Phone: ' + escapeHtml(company.phone || '') + ' | Email: ' + escapeHtml(company.email || '') + '</div>\n' +
    '  </div>\n' +
    '  <h2 style="color: #f5b342; font-size: 18px; margin-bottom: 10px;">' + escapeHtml(sheetName) + '</h2>\n' +
    '  <table border="1" cellpadding="5" cellspacing="0" style="border-collapse: collapse; width: 100%; font-size: 9px; font-family: Arial, sans-serif;">\n' +
    '    <thead>' + headerRow + '</thead>\n' +
    '    <tbody>' + rows + '</tbody>\n' +
    '  </table>\n' +
    '  <div style="margin-top: 10px; font-size: 8px; color: #666; text-align: right;">Generated on: ' + printDate + '</div>\n' +
    '</div>';
  
  if (!isLastSheet) {
    sheetHtml += '<div style="page-break-before: always;"></div>';
  }
  
  return sheetHtml;
}

function escapeHtml(str) {
  if (str === undefined || str === null) return '';
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

// =================== FINANCIAL REPORT (IFRS) ===================
function generateFinancialReportPDF(startDateStr, endDateStr) {
  try {
    const html = buildFinancialReportHTML(startDateStr, endDateStr);
    const blob = Utilities.newBlob(html, MimeType.HTML, 'financial_report.html');
    const pdfBlob = blob.getAs(MimeType.PDF);
    const base64 = Utilities.base64Encode(pdfBlob.getBytes());
    const filename = 'Financial_Report_' + startDateStr + '_to_' + endDateStr + '.pdf';
    return JSON.stringify({ success: true, base64: base64, filename: filename });
  } catch (error) {
    return JSON.stringify({ success: false, message: 'PDF generation error: ' + error.toString() });
  }
}

function emailFinancialReport(email, startDateStr, endDateStr) {
  try {
    const pdfResult = JSON.parse(generateFinancialReportPDF(startDateStr, endDateStr));
    if (!pdfResult.success) throw new Error(pdfResult.message);
    const pdfBytes = Utilities.base64Decode(pdfResult.base64);
    const pdfBlob = Utilities.newBlob(pdfBytes, MimeType.PDF, pdfResult.filename);
    MailApp.sendEmail({
      to: email,
      subject: 'Financial Report ' + startDateStr + ' to ' + endDateStr,
      body: 'Please find attached the IFRS financial report for the period ' + startDateStr + ' to ' + endDateStr + '.\n\nGenerated on: ' + new Date().toLocaleString(),
      attachments: [pdfBlob]
    });
    return '✅ Financial report sent to: ' + email;
  } catch (error) {
    return '❌ Email error: ' + error.toString();
  }
}

function buildFinancialReportHTML(startDateStr, endDateStr) {
  const startDate = new Date(startDateStr);
  const endDate = new Date(endDateStr);
  startDate.setHours(0,0,0,0);
  endDate.setHours(23,59,59,999);

  const transSheet = ss.getSheetByName('Transactions');
  if (!transSheet) throw new Error('Transactions sheet not found');
  const data = transSheet.getDataRange().getValues();

  let revenue = 0;
  let costOfSales = 0;
  let operatingExpenses = 0;
  let otherIncome = 0;

  let cashSales = 0;
  let creditSales = 0;
  let creditCollections = 0;
  let otherReceipts = 0;

  let cashPurchases = 0;
  let cashExpenses = 0;
  let otherCashPayments = 0;
  let duePayments = 0;

  let creditPurchases = 0;

  for (let i = 1; i < data.length; i++) {
    const row = data[i];
    const rowDate = new Date(row[1]);
    if (rowDate < startDate || rowDate > endDate) continue;
    if (row[10] !== 'Posted') continue;

    const type = row[2];
    const category = row[3];
    const amount = parseFloat(row[6]) || 0;

    if (type === 'Sales') {
      revenue += amount;
      if (category === 'Cash' || category === 'Bank') {
        cashSales += amount;
      } else if (category === 'Credit') {
        creditSales += amount;
      }
    } else if (type === 'Purchase') {
      costOfSales += amount;
      if (category === 'Paid') {
        cashPurchases += amount;
      } else if (category === 'Due') {
        creditPurchases += amount;
      }
    } else if (type === 'Expenses') {
      operatingExpenses += amount;
      if (category === 'Paid') {
        cashExpenses += amount;
      }
    } else if (type === 'Receive') {
      otherIncome += amount;
      if (category === 'Credit payment by Cash' || category === 'Credit payment by Bank') {
        creditCollections += amount;
      } else if (category === 'Cash' || category === 'Bank') {
        otherReceipts += amount;
      }
    } else if (type === 'Payment') {
      if (category === 'Paid') {
        otherCashPayments += amount;
      }
    } else if (type === 'Due Payment') {
      duePayments += amount;
    }
  }

  const cashInflowOperating = cashSales + creditCollections + otherReceipts;
  const cashOutflowOperating = cashPurchases + cashExpenses + otherCashPayments + duePayments;
  const netCashFlow = cashInflowOperating - cashOutflowOperating;

  const accountsReceivable = creditSales - creditCollections;
  const accountsPayable = creditPurchases - duePayments;
  const grossProfit = revenue - costOfSales;
  const netProfit = grossProfit - operatingExpenses + otherIncome;
  const retainedEarnings = netProfit;

  const company = getCompanyInfoParsed();
  const printDate = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "dd-MM-yyyy hh:mm a");
  const period = formatDateForPDF(startDateStr) + ' to ' + formatDateForPDF(endDateStr);

  function formatMoney(amount) {
    return '৳ ' + amount.toFixed(2);
  }

  function escape(s) {
    if (s === undefined || s === null) return '';
    return String(s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  return `<!DOCTYPE html>
  <html>
  <head>
      <meta charset="UTF-8">
      <style>
          body { font-family: Arial, sans-serif; margin: 0; padding: 20px; color: #333; }
          .report-container { max-width: 1000px; margin: 0 auto; border: 2px solid #000; padding: 30px; position: relative; }
          .header { text-align: center; margin-bottom: 30px; border-bottom: 2px solid #000; padding-bottom: 20px; }
          .company-name { font-size: 28px; font-weight: bold; color: #2c3e50; margin-bottom: 5px; }
          .company-details { font-size: 14px; color: #666; line-height: 1.6; }
          .report-title { text-align: center; font-size: 22px; font-weight: bold; margin: 20px 0; color: #2c3e50; }
          .period { text-align: center; font-size: 14px; color: #666; margin-bottom: 30px; }
          .section-title { font-size: 18px; font-weight: bold; margin: 20px 0 10px; border-bottom: 1px solid #ddd; padding-bottom: 5px; }
          .financial-table { width: 100%; border-collapse: collapse; margin: 15px 0; }
          .financial-table td, .financial-table th { padding: 8px; border: 1px solid #ddd; }
          .financial-table th { background-color: #f5f5f5; font-weight: bold; }
          .total-row { font-weight: bold; background-color: #f9f9f9; }
          .text-right { text-align: right; }
          .indent { padding-left: 20px; }
          .footer { text-align: center; margin-top: 40px; font-size: 11px; color: #666; border-top: 1px solid #ddd; padding-top: 10px; }
          @page { @bottom-right { content: "Page " counter(page) " of " counter(pages); font-size: 8px; color: #666; } }
      </style>
  </head>
  <body>
      <div class="report-container">
          <div class="header">
              <div class="company-name">${escape(company.name || 'Your Company')}</div>
              <div class="company-details">${escape(company.address || '')}<br>
              Phone: ${escape(company.phone || '')} | Email: ${escape(company.email || '')}</div>
          </div>
          <div class="report-title">Financial Statements</div>
          <div class="period">For the period ${period}</div>

          <div class="section-title">Statement of Profit or Loss</div>
          <table class="financial-table">
              <tr><td>Revenue from Sales</td><td class="text-right">${formatMoney(revenue)}</td></tr>
              <tr><td>Cost of Sales</td><td class="text-right">${formatMoney(costOfSales)}</td></tr>
              <tr class="total-row"><td>Gross Profit</td><td class="text-right">${formatMoney(grossProfit)}</td></tr>
              <tr><td>Operating Expenses</td><td class="text-right">${formatMoney(operatingExpenses)}</td></tr>
              <tr><td>Other Income</td><td class="text-right">${formatMoney(otherIncome)}</td></tr>
              <tr class="total-row"><td>Net Profit for the Period</td><td class="text-right">${formatMoney(netProfit)}</td></tr>
          </table>

          <div class="section-title">Statement of Financial Position</div>
          <table class="financial-table">
              <tr><td colspan="2"><strong>Assets</strong></td></tr>
              <tr><td class="indent">Cash and Cash Equivalents (change)</td><td class="text-right">${formatMoney(netCashFlow)}</td></tr>
              <tr><td class="indent">Trade Receivables (Credit Sales Outstanding)</td><td class="text-right">${formatMoney(accountsReceivable)}</td></tr>
              <tr class="total-row"><td>Total Assets</td><td class="text-right">${formatMoney(netCashFlow + accountsReceivable)}</td></tr>
              <tr><td colspan="2"><strong>Liabilities</strong></td></tr>
              <tr><td class="indent">Trade Payables (Credit Purchases Outstanding)</td><td class="text-right">${formatMoney(accountsPayable)}</td></tr>
              <tr class="total-row"><td>Total Liabilities</td><td class="text-right">${formatMoney(accountsPayable)}</td></tr>
              <tr><td colspan="2"><strong>Equity</strong></td></tr>
              <tr><td class="indent">Retained Earnings (Current Period Profit)</td><td class="text-right">${formatMoney(retainedEarnings)}</td></tr>
              <tr class="total-row"><td>Total Equity</td><td class="text-right">${formatMoney(retainedEarnings)}</td></tr>
              <tr class="total-row"><td>Total Liabilities and Equity</td><td class="text-right">${formatMoney(accountsPayable + retainedEarnings)}</td></tr>
          </table>

          <div class="section-title">Statement of Cash Flows</div>
          <table class="financial-table">
              <tr><td colspan="2"><strong>Cash Flows from Operating Activities</strong></td></tr>
              <tr><td class="indent">Cash received from customers</td><td class="text-right">${formatMoney(cashInflowOperating)}</td></tr>
              <tr><td class="indent">   - Cash sales</td><td class="text-right">${formatMoney(cashSales)}</td></tr>
              <tr><td class="indent">   - Collections from credit sales</td><td class="text-right">${formatMoney(creditCollections)}</td></tr>
              <tr><td class="indent">   - Other receipts</td><td class="text-right">${formatMoney(otherReceipts)}</td></tr>
              <tr><td class="indent">Cash paid to suppliers and employees</td><td class="text-right">${formatMoney(cashOutflowOperating)}</td></tr>
              <tr><td class="indent">   - Cash purchases</td><td class="text-right">${formatMoney(cashPurchases)}</td></tr>
              <tr><td class="indent">   - Cash expenses</td><td class="text-right">${formatMoney(cashExpenses)}</td></tr>
              <tr><td class="indent">   - Other cash payments</td><td class="text-right">${formatMoney(otherCashPayments + duePayments)}</td></tr>
              <tr class="total-row"><td>Net Cash from Operating Activities</td><td class="text-right">${formatMoney(netCashFlow)}</td></tr>
              <tr><td colspan="2"><strong>Cash Flows from Investing Activities</strong></td></tr>
              <tr><td class="indent">No investing activities recorded</td><td class="text-right">৳ 0.00</td></tr>
              <tr><td colspan="2"><strong>Cash Flows from Financing Activities</strong></td></tr>
              <tr><td class="indent">No financing activities recorded</td><td class="text-right">৳ 0.00</td></tr>
              <tr class="total-row"><td>Net Increase in Cash and Cash Equivalents</td><td class="text-right">${formatMoney(netCashFlow)}</td></tr>
          </table>

          <div class="footer">
              <p>This is a computer generated report. No signature required.</p>
              <p>Generated on: ${printDate}</p>
          </div>
      </div>
  </body>
  </html>`;
}

