      to: email,
      subject: 'Party Outstanding Report - ' + data.party,
      body: 'Please find attached the outstanding report for ' + data.party + '.\n\nGenerated on: ' + new Date().toLocaleString(),
      attachments: [pdfBlob]
    });
    return '✅ Report sent to: ' + email;
  } catch (error) {
    return '❌ Email error: ' + error.toString();
  }
}

// =================== VOUCHER NUMBER GENERATION ===================
function generateVoucherNumber(type, category, dateStr) {
  try {
    var date = new Date(dateStr);
    var month = Utilities.formatDate(date, Session.getScriptTimeZone(), "MMM").toUpperCase();
    var year = Utilities.formatDate(date, Session.getScriptTimeZone(), "yy");
    var typePrefix = {
      'Payment': 'PY',
      'Purchase': 'PU',
      'Expenses': 'EX',
      'Receive': 'RC',
      'Due Payment': 'DP',
      'Sales': 'SA'
    }[type] || 'V';
    var catMap = { 
      'Paid':'C', 
      'Due':'D', 
      'Cash':'C', 
      'Bank':'B', 
      'Credit':'R',
      'Credit payment by Cash':'PC',
      'Credit payment by Bank':'PB'
    };
    var catPrefix = catMap[category] || 'X';
    var prefix = typePrefix + catPrefix + '-' + month + year + '-';

    var transSheet = ss.getSheetByName('Transactions');
    var lastNumber = 0;
    if (transSheet) {
      var lastRow = transSheet.getLastRow();
      if (lastRow > 1) {
        var data = transSheet.getRange(2, 1, lastRow - 1, 1).getValues();
        for (var i = 0; i < data.length; i++) {
          var vNum = data[i][0];
          if (vNum && vNum.toString().startsWith(prefix)) {
            var parts = vNum.toString().split('-');
            if (parts.length === 3) {
              var num = parseInt(parts[2]);
              if (!isNaN(num) && num > lastNumber) lastNumber = num;
            }
          }
        }
      }
    }
    var newNumber = (lastNumber + 1).toString().padStart(4, '0');
    return prefix + newNumber;
  } catch (error) {
    var date = new Date(dateStr);
    var month = Utilities.formatDate(date, Session.getScriptTimeZone(), "MMM").toUpperCase();
    var year = Utilities.formatDate(date, Session.getScriptTimeZone(), "yy");
