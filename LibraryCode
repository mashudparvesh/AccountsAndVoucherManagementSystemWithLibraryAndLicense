// =================== POST VOUCHER TO SHEETS ===================
function postVoucherToSheets() {
  try {
    var voucherJson = SCRIPT_PROPERTIES.getProperty('CURRENT_VOUCHER');
    if (!voucherJson) return '❌ No voucher data found. Please create a voucher first.';
    var voucherData = JSON.parse(voucherJson);
    if (!voucherData.voucher) return '❌ Invalid voucher data.';
    if (voucherData.posted) return '⚠️ This voucher has already been posted.';

    var voucher = voucherData.voucher;
    var company = voucherData.company;
    var formattedTime = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "yyyy-MM-dd HH:mm:ss");
    var items = voucher.items;
    var party = voucher.party || '';

    for (var i = 0; i < items.length; i++) {
