// =================== SUMMARY UPDATE ===================
function updateSummarySheet(type, category, amount) {
  try {
    var summarySheet = ss.getSheetByName('Summary');
    if (!summarySheet) {
      summarySheet = ss.insertSheet('Summary');
      summarySheet.getRange('A1:D1').setValues([['Category/Type', 'Total Amount', 'Count', 'Last Updated']]);
    }
    var key = category + ' - ' + type;
    var data = summarySheet.getDataRange().getValues();
    var found = false;
    for (var i = 1; i < data.length; i++) {
      if (data[i][0] === key) {
        var currentAmount = parseFloat(data[i][1]) || 0;
        var currentCount = parseInt(data[i][2]) || 0;
        summarySheet.getRange(i + 1, 2).setValue(currentAmount + amount);
        summarySheet.getRange(i + 1, 3).setValue(currentCount + 1);
        summarySheet.getRange(i + 1, 4).setValue(new Date());
        found = true;
        break;
      }
    }
    if (!found) summarySheet.appendRow([key, amount, 1, new Date()]);
    summarySheet.getRange('B:B').setNumberFormat('"৳ "#,##0.00');
    summarySheet.getRange('D:D').setNumberFormat('yyyy-mm-dd hh:mm:ss');
  } catch (error) {
    console.error('Summary error: ' + error);
  }
}

// =================== FINANCIAL SUMMARY ===================
function getFinancialSummary() {
  try {
    var transSheet = ss.getSheetByName('Transactions');
    if (!transSheet) {
      return JSON.stringify({ success: false, message: 'Transactions sheet not found' });
    }
    var data = transSheet.getDataRange().getValues();
    var totalReceive = 0;
    var totalPaidOut = 0;
    var totalDuePayments = 0;
    var totalDueIncurred = 0;
    var totalCreditIncurred = 0;
    var totalCreditPayments = 0;

    for (var i = 1; i < data.length; i++) {
      var row = data[i];
      var type = row[2];
      var category = row[3];
      var amount = parseFloat(row[6]) || 0;
      var status = row[10];

      if (status !== 'Posted') continue;

      if (type === 'Receive') {
        totalReceive += amount;
        if (category === 'Credit payment by Cash' || category === 'Credit payment by Bank') {
          totalCreditPayments += amount;
        }
      }

      if ((type === 'Payment' || type === 'Expenses' || type === 'Purchase') &&
          (category === 'Paid' || category === 'Cash' || category === 'Bank')) {
        totalPaidOut += amount;
      }

      if (type === 'Due Payment') {
        totalDuePayments += amount;
      }

      if ((type === 'Payment' || type === 'Purchase' || type === 'Expenses') && category === 'Due') {
        totalDueIncurred += amount;
      }

      if (type === 'Sales' && category === 'Credit') {
        totalCreditIncurred += amount;
      }
    }

    var outstandingDue = totalDueIncurred - totalDuePayments;
    var outstandingCredit = totalCreditIncurred - totalCreditPayments;
    var netOutstanding = outstandingCredit - outstandingDue;
    var currentBalance = totalReceive - (totalPaidOut + totalDuePayments);

    return JSON.stringify({
      success: true,
      totalReceive: totalReceive,
      totalPaidOut: totalPaidOut,
      totalDuePayments: totalDuePayments,
      outstandingDue: outstandingDue,
      outstandingCredit: outstandingCredit,
      netOutstanding: netOutstanding,
      currentBalance: currentBalance
    });
  } catch (error) {
    return JSON.stringify({ success: false, message: error.toString() });
  }
}

// =================== DELETE VOUCHER ===================
function deleteVoucher(voucherNumber) {
  try {
    var transSheet = ss.getSheetByName('Transactions');
    if (!transSheet) {
      return JSON.stringify({ success: false, message: 'Transactions sheet not found' });
    }

    var transData = transSheet.getDataRange().getValues();
    var rowsToDelete = [];
    var items = [];

    for (var i = 1; i < transData.length; i++) {
      if (transData[i][0] && transData[i][0].toString().trim() === voucherNumber.trim()) {
        rowsToDelete.push(i + 1);
        items.push({
          type: transData[i][2],
          category: transData[i][3],
          amount: parseFloat(transData[i][6]) || 0
        });
      }
    }

    if (rowsToDelete.length === 0) {
      return JSON.stringify({ success: false, message: 'Voucher not found in Transactions' });
    }

    for (var j = rowsToDelete.length - 1; j >= 0; j--) {
      transSheet.deleteRow(rowsToDelete[j]);
    }

    var type = items[0].type;
    var category = items[0].category;

    var typeSheet = ss.getSheetByName(type);
    if (typeSheet) {
      var typeData = typeSheet.getDataRange().getValues();
      var typeRows = [];
      for (var k = 1; k < typeData.length; k++) {
        if (typeData[k][0] && typeData[k][0].toString().trim() === voucherNumber.trim()) {
          typeRows.push(k + 1);
        }
      }
      for (var k = typeRows.length - 1; k >= 0; k--) {
        typeSheet.deleteRow(typeRows[k]);
      }
    }

    var catSheet = ss.getSheetByName(category);
    if (catSheet) {
      var catData = catSheet.getDataRange().getValues();
      var catRows = [];
      for (var l = 1; l < catData.length; l++) {
        if (catData[l][0] && catData[l][0].toString().trim() === voucherNumber.trim()) {
          catRows.push(l + 1);
        }
      }
      for (var l = catRows.length - 1; l >= 0; l--) {
        catSheet.deleteRow(catRows[l]);
      }
    }

    var summarySheet = ss.getSheetByName('Summary');
    if (summarySheet) {
      var summaryData = summarySheet.getDataRange().getValues();
      for (var m = 0; m < items.length; m++) {
        var item = items[m];
        var key = item.category + ' - ' + item.type;
        for (var n = 1; n < summaryData.length; n++) {
          if (summaryData[n][0] === key) {
            var currentAmount = parseFloat(summaryData[n][1]) || 0;
            var currentCount = parseInt(summaryData[n][2]) || 0;
            var newAmount = Math.max(0, currentAmount - item.amount);
            var newCount = Math.max(0, currentCount - 1);
            summarySheet.getRange(n + 1, 2).setValue(newAmount);
            summarySheet.getRange(n + 1, 3).setValue(newCount);
            summarySheet.getRange(n + 1, 4).setValue(new Date());
            break;
          }
        }
      }
    }

    return JSON.stringify({ success: true, message: 'Voucher deleted successfully' });
  } catch (error) {
    return JSON.stringify({ success: false, message: error.toString() });
  }
}

