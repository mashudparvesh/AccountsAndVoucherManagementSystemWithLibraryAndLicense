// =================== PARTY OUTSTANDING SUMMARY ===================
function getPartyOutstanding(filterType) {
  try {
    var transSheet = ss.getSheetByName('Transactions');
    if (!transSheet) return JSON.stringify({ success: false, message: 'Transactions sheet not found' });

    var data = transSheet.getDataRange().getValues();
    var partyBalances = {};

    for (var i = 1; i < data.length; i++) {
      var row = data[i];
      var party = row[7];
      if (!party) continue;

      var type = row[2];
      var category = row[3];
      var amount = parseFloat(row[6]) || 0;
      var status = row[10];

      if (status !== 'Posted') continue;

      var sign = 0;
      if (type === 'Payment' || type === 'Purchase' || type === 'Expenses') {
        sign = 1;
      } else if (type === 'Receive') {
        sign = 1;
      } else if (type === 'Sales') {
        if (category === 'Credit') {
          sign = -1;
        } else {
          sign = 0;
        }
      } else if (type === 'Due Payment') {
        sign = -1;
      }

      if (sign === 0) continue;

      if (!partyBalances[party]) {
        partyBalances[party] = 0;
      }
      partyBalances[party] += sign * amount;
    }

    var partySheet = ss.getSheetByName('Parties');
    var partyDetails = {};
    if (partySheet) {
      var pData = partySheet.getDataRange().getValues();
      for (var j = 1; j < pData.length; j++) {
        var name = pData[j][0];
        partyDetails[name] = {
          type: pData[j][1] || 'Buyer',
          contact: pData[j][2] || '',
          email: pData[j][3] || '',
          address: pData[j][4] || ''
        };
      }
    }

    var result = [];
    for (var name in partyBalances) {
      var pType = partyDetails[name] ? partyDetails[name].type : 'Buyer';
      if (filterType && filterType !== 'All' && pType !== filterType) continue;
      result.push({
        name: name,
        type: pType,
        balance: partyBalances[name],
        contact: partyDetails[name] ? partyDetails[name].contact : '',
        email: partyDetails[name] ? partyDetails[name].email : '',
        address: partyDetails[name] ? partyDetails[name].address : ''
      });
    }

    result.sort((a, b) => a.name.localeCompare(b.name));
    return JSON.stringify({ success: true, parties: result });
  } catch (error) {
    return JSON.stringify({ success: false, message: error.toString() });
  }
}

function getPartyTransactions(partyName, limit = 5) {
  try {
    var transSheet = ss.getSheetByName('Transactions');
    if (!transSheet) return JSON.stringify({ success: false, message: 'Transactions sheet not found' });

    var data = transSheet.getDataRange().getValues();
    var transactions = [];

    for (var i = 1; i < data.length; i++) {
      var row = data[i];
      if (row[7] === partyName && row[10] === 'Posted') {
        transactions.push({
          voucherNo: row[0],
          date: storeDateSimply(row[1]),
          type: row[2],
          category: row[3],
          particulars: row[5],
          amount: parseFloat(row[6]) || 0,
          createdAt: row[11]
        });
      }
    }

    transactions.sort((a, b) => new Date(b.date) - new Date(a.date));
    var recent = transactions.slice(0, limit);
    return JSON.stringify({ success: true, transactions: recent });
  } catch (error) {
    return JSON.stringify({ success: false, message: error.toString() });
  }
}

