        storeDateSimply(voucher.date),
        voucher.type,
        voucher.category,
        item.sl,
        item.particulars,
        parseFloat(item.amount),
        party,
        company.name || '',
        company.preparedBy || '',
        'Posted',
        formattedTime
      ]);

      var typeSheet = ss.getSheetByName(voucher.type);
      if (!typeSheet) typeSheet = ss.insertSheet(voucher.type);
      typeSheet.appendRow([
        voucher.voucherNumber,
        storeDateSimply(voucher.date),
        voucher.category,
        item.sl,
        item.particulars,
        parseFloat(item.amount),
        party,
        'Posted'
      ]);

      var catSheet = ss.getSheetByName(voucher.category);
      if (!catSheet) catSheet = ss.insertSheet(voucher.category);
      catSheet.appendRow([
        voucher.voucherNumber,
        storeDateSimply(voucher.date),
        voucher.type,
        item.sl,
        item.particulars,
        parseFloat(item.amount),
        party,
        'Posted'
      ]);

      updateSummarySheet(voucher.type, voucher.category, parseFloat(item.amount));
